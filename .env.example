# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-generate-with-secrets-token-urlsafe-64
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(16)).decode())"
ENCRYPTION_SALT=change-me-generate-with-os-urandom-16

# ── Database ──────────────────────────────────────────────────────────────────
# AWS RDS: use postgresql+asyncpg:// for async driver (FastAPI), postgresql:// for Alembic migrations
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
SYNC_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash Redis (TLS): rediss://default:<token>@<host>:<port>
# Local dev: redis://localhost:6379
REDIS_URL=rediss://default:token@host:port

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-generate-with-secrets-token-urlsafe-64
JWT_ALGORITHM=HS256

# ── CORS & Service URLs ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://interviewiq.in,https://www.interviewiq.in
FRONTEND_URL=https://interviewiq.in
BACKEND_URL=https://api.interviewiq.in

# ── OAuth (optional — skip for email/password only auth) ─────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
#   Authorised redirect URI: https://<backend-url>/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers → New OAuth App
#   Authorization callback URL: https://<backend-url>/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── OpenRouter (free tier) ────────────────────────────────────────────────────
# Get key at https://openrouter.ai/keys (free, no credit card needed)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Cohere (embeddings) ───────────────────────────────────────────────────────
# Get key at https://cohere.com/api-keys (free trial available)
COHERE_API_KEY=your-cohere-api-key

# ── Per-agent model selection ─────────────────────────────────────────────────
# OpenRouter free models (confirmed available 2026-03-24):
#   openrouter/nvidia/nemotron-3-nano-30b-a3b:free
#   openrouter/nvidia/nemotron-3-super-120b-a12b:free
# Cloud paid: claude-sonnet-4-6 | gpt-4o | gemini-1.5-flash
INTERVIEWER_MODEL=openrouter/nvidia/nemotron-3-nano-30b-a3b:free
EVALUATOR_MODEL=openrouter/nvidia/nemotron-3-nano-30b-a3b:free
PARSER_MODEL=openrouter/nvidia/nemotron-3-nano-30b-a3b:free
FOLLOWUP_MODEL=openrouter/nvidia/nemotron-3-nano-30b-a3b:free
REPORT_MODEL=openrouter/nvidia/nemotron-3-nano-30b-a3b:free

# ── Embeddings ────────────────────────────────────────────────────────────────
# Cohere embed-english-v3.0 → 1024-dim vectors (requires COHERE_API_KEY above)
EMBEDDINGS_MODEL=cohere/embed-english-v3.0

# ── Razorpay (payment gateway — optional for initial deploy) ──────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=
# Prices in paise (INR × 100). Uncomment to override defaults.
# RAZORPAY_1_CREDIT_AMOUNT=70000    # ₹700
# RAZORPAY_5_CREDIT_AMOUNT=299000   # ₹2,990
# RAZORPAY_10_CREDIT_AMOUNT=499000  # ₹4,990
RAZORPAY_CURRENCY=INR

# ── Admin access ──────────────────────────────────────────────────────────────
ADMIN_EMAILS=youremail@example.com
# ADMIN_USER_IDS=uuid1,uuid2

# ── AWS (document storage — optional) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=interviewiq

# ── Lambda-specific (only needed when deploying to AWS Lambda) ─────────────────
# SESSION_CLEANUP_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/interviewiq-session-cleanup
